# Supabase Configuration (Frontend - Safe)
# DO NOT add secrets like OCR_SPACE_API_KEY or service role keys here!
# Only public / anon keys should be prefixed with VITE_

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------
# Server-Side Configuration (Supabase Secrets - Critical)
# These should NOT be in your local .env file.
# Set them using: npx supabase secrets set KEY=VALUE
# ---------------------------------------------------------

# (NEW) OCR.space API for verification
OCR_SPACE_API_KEY=your_ocr_space_api_key

# (DEPRECATED) Google Cloud Vision OCR for verification
# GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key

VERIFICATION_CONFIDENCE_THRESHOLD=0.85
