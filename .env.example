# Frontend Environment Variables (Safe for Public)
VITE_SUPABASE_URL=your_project_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase Secrets (NEVER EXPOSE IN FRONTEND .ENV)
# Set these using: npx supabase secrets set KEY=VALUE
# -----------------------------------------------------------------------------
# RESEND_API_KEY=your_resend_api_key
# FROM_EMAIL="MakerHQ <notifications@yourdomain.com>"
# APP_BASE_URL=https://your-production-url.com
# OCR_SPACE_API_KEY=your_ocr_space_key
# VERIFICATION_CONFIDENCE_THRESHOLD=0.85
